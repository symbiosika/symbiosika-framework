# Development/Staging Dockerfile
# Contains: PostgreSQL (pgvector) + Bun + Backend App + Frontend
# Usage: 
#   From project root: docker build -f Dockerfile.dev -t business-app-dev .
#   Or: cd .. && docker build -f business-app/Dockerfile.dev -t business-app-dev business-app

FROM ubuntu:22.04 AS base

# Avoid interactive prompts during package installation
ENV DEBIAN_FRONTEND=noninteractive

# Install system dependencies
RUN apt-get update && apt-get install -y \
    curl \
    ca-certificates \
    gnupg \
    lsb-release \
    unzip \
    sudo \
    bash \
    && echo "root ALL=(ALL) NOPASSWD: ALL" >> /etc/sudoers \
    && rm -rf /var/lib/apt/lists/*

# Stage: PostgreSQL with pgvector
FROM base AS postgres

# Install PostgreSQL 17 with pgvector
RUN curl -fsSL https://www.postgresql.org/media/keys/ACCC4CF8.asc | gpg --dearmor -o /usr/share/keyrings/postgresql.gpg \
    && echo "deb [signed-by=/usr/share/keyrings/postgresql.gpg] http://apt.postgresql.org/pub/repos/apt $(lsb_release -cs)-pgdg main" > /etc/apt/sources.list.d/pgdg.list \
    && apt-get update \
    && apt-get install -y postgresql-17 postgresql-contrib-17 \
    && rm -rf /var/lib/apt/lists/*

# Install pgvector extension (v0.7.0+ for PostgreSQL 17 compatibility)
RUN apt-get update && apt-get install -y \
    build-essential \
    postgresql-server-dev-17 \
    git \
    && cd /tmp \
    && git clone --branch v0.7.0 https://github.com/pgvector/pgvector.git \
    && cd pgvector \
    && make \
    && make install \
    && cd / \
    && rm -rf /tmp/pgvector \
    && apt-get purge -y build-essential postgresql-server-dev-17 git \
    && apt-get autoremove -y \
    && rm -rf /var/lib/apt/lists/*

# Stage: Bun installation
FROM postgres AS bun

# Install Bun
RUN curl -fsSL https://bun.sh/install | bash
ENV PATH="/root/.bun/bin:${PATH}"

# Stage: Final - Application
FROM bun AS final

# Set working directory
WORKDIR /app

# Copy backend files
COPY backend/package.json backend/bun.lock ./backend/
COPY backend/drizzle.config.ts ./backend/
COPY backend/drizzle-sql ./backend/drizzle-sql/
COPY backend/framework ./backend/framework/
COPY backend/src ./backend/src/
COPY backend/seeds ./backend/seeds/
COPY backend/public ./backend/public/
COPY backend/static ./backend/static/
COPY backend/tsconfig.json ./backend/
# Copy frontend files
COPY frontend/package.json frontend/bun.lock ./frontend/
COPY frontend/vite.config.ts ./frontend/
COPY frontend/tsconfig*.json ./frontend/
COPY frontend/env.d.ts ./frontend/
COPY frontend/index.html ./frontend/
COPY frontend/public ./frontend/public/
COPY frontend/src ./frontend/src/

# Install backend dependencies
WORKDIR /app/backend
RUN bun install

# Install frontend dependencies and build
WORKDIR /app/frontend
RUN rm -f bun.lockb && bun install
# Use build-only to skip type-check during Docker build (faster, type-check can be done in CI)
RUN bun run build-only || bun run build

# Copy built frontend to backend static directory (Vite outDir: dist/static/app per vite.config.ts)
RUN mkdir -p /app/backend/static/app && \
    cp -r /app/frontend/dist/static/app/* /app/backend/static/app/

# Create PostgreSQL data directory and set permissions
RUN mkdir -p /var/lib/postgresql/17/main \
    && chown -R postgres:postgres /var/lib/postgresql \
    && chmod 700 /var/lib/postgresql/17/main

# Copy startup script and fix line endings (Windows CRLF -> Unix LF)
COPY docker-start.sh /app/start.sh
RUN sed -i 's/\r$//' /app/start.sh && \
    chmod +x /app/start.sh && \
    test -f /app/start.sh && \
    head -1 /app/start.sh | grep -q '#!/bin/bash' || (echo "Error: Invalid shebang" && exit 1)

# Create log directories with proper permissions
RUN mkdir -p /var/log/postgresql /app/logs && \
    chown postgres:postgres /var/log/postgresql && \
    chmod 755 /var/log/postgresql && \
    chmod 777 /app/logs

# Expose ports
EXPOSE 3100

# Start the application (which will start PostgreSQL first)
# Use bash explicitly to ensure proper execution
CMD ["/bin/bash", "/app/start.sh"]