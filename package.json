{
  "name": "symbiosika-framework",
  "version": "0.12.8",
  "author": "Symbiosika GmbH",
  "main": "./lib/index.js",
  "devDependencies": {
    "@electric-sql/pglite": "^0.5.2",
    "@electric-sql/pglite-pgvector": "^0.0.3",
    "@electric-sql/pglite-socket": "^0.2.2",
    "@types/bun": "^1.3.3",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/nodemailer": "^6.4.16",
    "@types/pg": "^8.15.5",
    "@types/turndown": "^5.0.6",
    "drizzle-kit": "^0.31.5",
    "prettier": "^3.3.3",
    "ts-morph": "^22.0.0",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "@hono/standard-validator": "^0.1.5",
    "@hono/swagger-ui": "0.5.2",
    "@hono/valibot-validator": "0.5.3",
    "@mozilla/readability": "^0.6.0",
    "@valibot/to-json-schema": "^1.5.0",
    "@ai-sdk/mistral": "^3.0.5",
    "@ai-sdk/valibot": "^2.0.10",
    "ai": "^6.0.48",
    "cron": "4.3.3",
    "csv": "6.4.1",
    "drizzle-orm": "0.44.6",
    "drizzle-valibot": "0.4.2",
    "hono": "4.10.1",
    "hono-openapi": "1.1.0",
    "jsonwebtoken": "9.0.2",
    "linkedom": "^0.18.12",
    "nanoid": "5.1.6",
    "nodemailer": "7.0.9",
    "pg": "8.16.3",
    "pgvector": "0.2.1",
    "postgres": "3.4.7",
    "turndown": "^7.2.4",
    "turndown-plugin-gfm": "^1.0.2",
    "valibot": "^1.2.0",
    "@simplewebauthn/server": "^13.0.0"
  },
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "default": "./lib/index.js"
    }
  },
  "description": "Kinaut Webserver",
  "engines": {
    "bun": ">=1.0.0"
  },
  "files": [
    "lib/**/*",
    "static/**/*",
    "public/**/*",
    "drizzle-sql/**/*"
  ],
  "types": "./lib/index.d.ts",
  "homepage": "https://github.com/symbiosika/kinaut_webserver",
  "keywords": [],
  "license": "proprietary",
  "scripts": {
    "dev": "bun --hot run demo.ts",
    "dev:inspect": "bun --inspect --hot run demo.ts",
    "db:local": "bun run ./.scripts/local-db-server.ts",
    "dev:local": "pglite-server --db=./dev-db/pglite --extensions=vector -m 20 -p 5432 --run 'bun run framework:migrate && bun run dev'",
    "framework:migrate": "drizzle-kit migrate",
    "framework:push": "drizzle-kit push",
    "framework:generate": "drizzle-kit generate",
    "framework:studio": "drizzle-kit studio",
    "build": "tsc",
    "clean": "rm -rf ./lib/",
    "release:patch": "tsc && npm version patch && git push --follow-tags && npm publish",
    "release:minor": "tsc && npm version minor && git push --follow-tags && npm publish",
    "release:major": "tsc && npm version major && git push --follow-tags && npm publish",
    "sync-skills": "bun run ./.scripts/sync-skills.ts",
    "init": "bun run ./.scripts/init.ts"
  }
}
