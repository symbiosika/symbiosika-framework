# Docker Compose project name (optional, default: app)
# PROJECT_NAME=symbiosika-framework

# Webserver
WRITE_DEBUG_FILES=true
CRON_LOG=true

# URL
# BASE_URL=http://localhost:3000

# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=pg
POSTGRES_PASSWORD=pg
POSTGRES_DB=dev
#POSTGRES_CA='-----BEGIN CERTIFICATE-----
#xxx
#-----END CERTIFICATE-----'
# Set to true to verify server hostname against the certificate (default: false)
#POSTGRES_CHECK_IDENTITY=false

# Webserver Settings
# ALLOWED_ORIGINS="http://localhost:5173"

# Parsing
#PDF_PARSER_SERVICE="llama"
#PDF_PARSER_SERVICE="local"
#PDF_PARSER_SERVICE="mistral"
#LOCAL_PDF_PARSER_API_KEY="demo-xxx"
#LOCAL_PDF_PARSER_BASE_URL="https://document-services.perlecto.de"
#LLAMA_CLOUD_API_KEY=llx-xxx

# MISTRAL_API_KEY
# OPENAI_API_KEY

# Encryption
# SECRETS_AES_KEY is the master key (key version 1) used to encrypt tenant secrets.
# Existing setups only need this — secrets are stamped with the key version that
# encrypted them (defaults to 1), so a single SECRETS_AES_KEY stays fully backwards compatible.
#
# Key rotation (optional, future): to rotate, add the new key as SECRETS_AES_KEY_V2
# (V3, ...) and set SECRETS_AES_KEY_VERSION to the new current version. New secrets are
# then encrypted with that version while older secrets keep decrypting with their stored
# key version. Leave SECRETS_AES_KEY_VERSION unset to keep using version 1.
SECRETS_AES_KEY=
SECRETS_AES_IV=
# SECRETS_AES_KEY_VERSION=1
# SECRETS_AES_KEY_V2=

JWT_PUBLIC_KEY=
JWT_PRIVATE_KEY=

# Email
# Set SMTP_HOST=console.localhost to log emails to console instead of sending
SMTP_DEBUG=true
SMTP_HOST=console.localhost
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_DEFAULT_SENDER=noreply@localhost
SMTP_PASS=

# TLS
# TLS_CERT_PATH=/usr/src/app/certs/server.crt
# TLS_KEY_PATH=/usr/src/app/certs/server.key